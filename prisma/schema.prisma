generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "file:./dev.db" 
}

model Project {
  id               String   @id @default(cuid())
  name             String   
  code             String?  
  totalLots        Int      
  
  status           String   @default("ACTIVE") 

  chuaBanHanhCount Int      @default(0)
  chuaKiemKeCount  Int      @default(0)
  xacNhanCount     Int      @default(0)
  duThaoCount      Int      @default(0)
  thamDinhCount    Int      @default(0)
  pheDuyetCount    Int      @default(0)

  projectStates    ProjectState[]
  histories        ProjectHistory[] 
  
  // MỚI: Liên kết 1-1 với bảng Chi tiết
  details          ProjectDetail?   

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// MỚI: Bảng lưu thông tin chi tiết dự án
model ProjectDetail {
  id           String  @id @default(cuid())
  tienDoDuAn   String? // Option: Đấu giá, HTKT, Trường, Đường, Ngoài ngân sách, Trung ương
  chiTiet      String? // Option: Chưa nhận mốc, Đã nhận mốc, Chưa có mốc
  donViDoDac   String?
  canBoGPMB    String?
  mo           String?
  ghiChu       String?

  projectId    String  @unique
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectState {
  id        String  @id @default(cuid())
  name      String  
  color     String? 
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectHistory {
  id        String   @id @default(cuid())
  note      String   
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}